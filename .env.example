# Google Sheets Backend Web App URL (Apps Script Deployment URL)
GOOGLE_SHEET_URL=https://script.google.com/macros/s/YOUR_GOOGLE_APPS_SCRIPT_ID/exec

# Security tokens (use cryptographically secure random values)
EXPORT_TOKEN=your_secure_export_token_here
GOOGLE_SCRIPT_SECRET=your_secure_apps_script_secret_here
